{
  "name": "lovelygit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "generate:csharp-types": "typesharp generate --config ./typesharp.config.json --no-incremental && node ./scripts/generate-native-message-contracts.mjs",
    "generate:types": "pnpm generate:csharp-types",
    "check:types": "pnpm generate:csharp-types && git diff --exit-code -- src/generated/types.ts src/generated/native-message-contracts.ts",
    "prebuild": "pnpm generate:csharp-types",
    "preview": "vite preview",
    "watch": "pnpm generate:csharp-types && node ./scripts/watch.mjs",
    "format": "pnpm exec biome check src --write",
    "lint": "pnpm format",
    "lint:fix": "pnpm exec biome check src --write",
    "git-binaries:bump": "node scripts/bump-dugite-binaries.ts",
    "git-binaries:download": "node scripts/download-local-dugite-binaries.ts",
    "prod": "pnpm build",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-use-system-theme": "^1.1.1",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@siyavuyachagi/typesharp": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
